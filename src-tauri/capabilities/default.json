{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Permissions minimales LuxePOS (principle of least privilege) — fs/process retirés, save/load JSON via commandes Rust custom uniquement.",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "core:window:default",
        "core:window:allow-close",
        "core:window:allow-minimize",
        "core:window:allow-maximize",
        "core:window:allow-toggle-maximize",
        "core:window:allow-set-fullscreen",
        "core:webview:default",
        "core:event:default",
        "core:app:default",
        "core:path:default",
        "core:resources:default",
        "dialog:default",
        "shell:allow-open",
        "updater:default"
    ]
}

{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "LuxePOS",
    "version": "5.14.9",
    "identifier": "ch.luxepos.desktop",
    "build": {
        "beforeDevCommand": "",
        "beforeBuildCommand": "",
        "frontendDist": "../dist-web",
        "devUrl": "http://localhost:8765/"
    },
    "app": {
        "windows": [
            {
                "title": "LuxePOS — Bijouterie",
                "width": 1280,
                "height": 820,
                "minWidth": 900,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "transparent": false,
                "url": "luxepos-final.html"
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["nsis"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.ico",
            "icons/icon.png"
        ],
        "publisher": "Maëlle Studio",
        "category": "Business",
        "shortDescription": "Caisse & gestion de bijouterie artisanale",
        "longDescription": "LuxePOS — l'outil artisan de votre boutique. Caisse, stock, clientèle, comptabilité, assistant Lumi. Conçu pour les bijoutiers indépendants.",
        "windows": {
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "installMode": "perMachine",
                "languages": ["French", "English"],
                "displayLanguageSelector": false
            }
        }
    },
    "plugins": {}
}
